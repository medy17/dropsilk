{
  "name": "dropsilk",
  "version": "3.1.0",
  "author": "Ahmed medy17 <> (ahmed@dropsilk.xyz) (https://github.com/medy17)",
  "description": "A modern, privacy-focused, peer-to-peer file transfer application built with WebRTC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/medy17/dropsilk.git"
  },
  "main": "electron/main.js",
  "scripts": {
    "gen:version": "node scripts/generate-version.js",
    "gen:locales": "node scripts/generate-locales.js",
    "dev": "bun gen:version && bun gen:locales && bun update-themes && vite --host",
    "build:web": "bun gen:version && bun gen:locales && bun update-themes && vite build",
    "dev:electron": "concurrently \"bun dev\" \"cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build:electron": "bun gen:version && bun gen:locales && bun update-themes && cross-env VITE_API_BASE_URL=https://dropsilk-backend.onrender.com vite build --base=./ && electron-builder",
    "preview": "vite preview",
    "update-locales": "node scripts/update-locales.js",
    "update-themes": "node scripts/update-themes.js",
    "loc": "node scripts/loc.js",
    "test": "bun gen:locales && bun update-themes && vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "bun gen:locales && bun update-themes && vitest run",
    "lint": "eslint .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": "eslint --fix"
  },
  "build": {
    "appId": "com.dropsilk.app",
    "productName": "DropSilk",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/favicons/favicon-512x512.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/favicons/favicon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/favicons"
    }
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "ag-psd": "^30.1.1",
    "dompurify": "^3.4.1",
    "electron-squirrel-startup": "^1.0.1",
    "heic2any": "^0.0.4",
    "highlight.js": "^11.11.1",
    "i18next": "^26.0.7",
    "i18next-browser-languagedetector": "^8.2.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "marked": "^17.0.6",
    "pdfjs-dist": "^5.6.205",
    "qr-scanner": "^1.4.2",
    "qrcode": "^1.5.4",
    "sortablejs": "^1.15.7",
    "uploadthing": "^7.7.4",
    "wavesurfer.js": "^7.12.6",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "picocolors": "^1.1.1",
    "vite": "^8.0.10",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vitest": "^4.1.5"
  }
}
